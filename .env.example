# Application
APP_NAME=local-ai-platform
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# Telemetry
OTEL_SERVICE_NAME=local-ai-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json